{
  "name": "gutian/parakit",
  "description": "The payment kit for Kurdistan and Iraq — Laravel-native.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^11.0 || ^12.0",
    "illuminate/database": "^11.0 || ^12.0",
    "illuminate/http": "^11.0 || ^12.0",
    "illuminate/support": "^11.0 || ^12.0",
    "firebase/php-jwt": "^7.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0 || ^10.0",
    "pestphp/pest": "^3.0",
    "pestphp/pest-plugin-laravel": "^3.0",
    "phpstan/phpstan": "^2.1",
    "larastan/larastan": "^3.0"
  },
  "autoload": {
    "psr-4": { "Gutian\\Parakit\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Gutian\\Parakit\\Tests\\": "tests/" }
  },
  "extra": {
    "laravel": {
      "providers": ["Gutian\\Parakit\\ParakitServiceProvider"],
      "aliases": { "Payment": "Gutian\\Parakit\\Facades\\Payment" }
    }
  },
  "scripts": {
    "test": "pest",
    "stan": "phpstan analyse"
  },
  "config": {
    "allow-plugins": { "pestphp/pest-plugin": true }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
